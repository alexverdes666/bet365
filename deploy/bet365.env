# =============================================================================
# Bet365 Stream Configuration
# =============================================================================

# ─── Proxies (for English content, use UK LTESocks ports) ────────────────────
# Multiple proxies for failover — comma-separated
# Format: socks5://login:password@proxyserver:port
PROXY_URLS=socks5://LOGIN:PASSWORD@ap1.ltesocks.io:PORT1,socks5://LOGIN:PASSWORD@ap1.ltesocks.io:PORT2

# ─── LTESocks API (auto IP reset on block) ───────────────────────────────────
# API token from https://ltesocks.io dashboard
LTESOCKS_API_TOKEN=your_api_token_here
# Port IDs matching PROXY_URLS order (from /v2/ports response)
LTESOCKS_PORT_IDS=port_id_1,port_id_2

# ─── WebSocket server ────────────────────────────────────────────────────────
WS_PORT=8765
WS_TOKEN=change_me_to_a_secure_token

# ─── Worker pool (optimized for 64GB RAM / 12 CPU cores) ─────────────────────
TABS_PER_BROWSER=8
MAX_WORKERS=0
CONCURRENCY=10
SNAPSHOT_INTERVAL=10
